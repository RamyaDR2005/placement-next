# ─── Database ─────────────────────────────────────────────────────────────────
# Pooled URL used by the Prisma runtime (PrismaPg adapter)
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"
# Non-pooled URL used exclusively by Prisma Migrate / db push
DIRECT_URL="postgresql://username:password@host:5432/database?sslmode=require"

# ─── NextAuth v5 ───────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="your_auth_secret_here"
# NextAuth v5 uses AUTH_URL (not NEXTAUTH_URL). No trailing slash.
# Local dev: AUTH_URL="http://localhost:3500"
AUTH_URL="https://yourdomain.com"

# ─── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ─── Email (AWS SES SMTP) ─────────────────────────────────────────────────────
# The app uses AWS SES via SMTP. Create SMTP credentials in AWS SES console:
# IAM → SES → SMTP Settings → Create SMTP Credentials
AWS_SES_ACCESS_KEY_ID="your_ses_smtp_username"
AWS_SES_SECRET_ACCESS_KEY="your_ses_smtp_password"
EMAIL_FROM="Placement Portal <noreply@yourdomain.com>"

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
# Endpoint format: https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
CLOUDFLARE_R2_ACCESS_KEY_ID="your_r2_access_key_id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
CLOUDFLARE_R2_BUCKET_NAME="placement-portal"
# Public URL for serving files (custom domain or R2 dev URL)
CLOUDFLARE_R2_PUBLIC_DOMAIN="https://files.yourdomain.com"

# ─── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:admin@yourdomain.com"

# ─── Cron Job Security ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
CRON_SECRET="your_cron_secret_here"
